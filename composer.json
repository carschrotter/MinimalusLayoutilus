{
    "name": "mnhcc/minimalus-layoutilus",
    "description": "Lightweight PHP template engine and MVC framework for building highly customizable websites with minimal setup",
    "type": "project",
    "license": "LGPL-2.1-or-later",
    "keywords": ["template-engine", "mvc", "lightweight", "website", "php54"],
    "homepage": "https://github.com/carschrotter/MinimalusLayoutilus",
    "authors": [
        {
            "name": "Michael Hegenbarth (carschrotter)",
            "email": "mnh@mn-hegenbarth.de",
            "homepage": "https://github.com/carschrotter",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/carschrotter/MinimalusLayoutilus/issues",
        "source": "https://github.com/carschrotter/MinimalusLayoutilus"
    },
    "require": {
        "php": ">=5.4",
        "ext-json": "*",
        "ext-pdo": "*",
        "mnhcc/ml-core": "^0.9",
        "mnhcc/ml-bugcatcher": "^0.9",
        "mnhcc/ml-mvc": "^0.9"
    },
    "autoload": {
        "classmap": [
            "classes/"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^5.7"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
