{
    "name": "mnhcc/minimalus-layoutilus",
    "description": "Minimalus Layoutilus — example project using the mnhcc/ml-* framework packages",
    "type": "project",
    "license": "LGPL-2.1-or-later",
    "authors": [
        {
            "name": "Michael Hegenbarth (carschrotter)",
            "email": "mnh@mn-hegenbarth.de"
        }
    ],
    "require": {
        "php": ">=5.4",
        "ext-json": "*",
        "ext-pdo": "*",
        "mnhcc/ml-core": "*",
        "mnhcc/ml-bugcatcher": "*",
        "mnhcc/ml-mvc": "*"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../ml-core"
        },
        {
            "type": "path",
            "url": "../ml-bugcatcher"
        },
        {
            "type": "path",
            "url": "../ml-mvc"
        }
    ],
    "autoload": {
        "classmap": [
            "classes/"
        ]
    },
    "minimum-stability": "dev",
    "require-dev": {
        "kint-php/kint": "4.x-dev",
        "phpunit/phpunit": "^5.7"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}
