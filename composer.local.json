{
    "name": "mnhcc/minimalus-layoutilus",
    "description": "Lightweight PHP template engine and MVC framework for building highly customizable websites with minimal setup",
    "type": "project",
    "license": "LGPL-2.1-or-later",
    "authors": [
        {
            "name": "Michael Hegenbarth (carschrotter)",
            "email": "mnh@mn-hegenbarth.de",
            "homepage": "https://github.com/carschrotter",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=5.4",
        "ext-json": "*",
        "mnhcc/ml-core": "*",
        "mnhcc/ml-bugcatcher": "*",
        "mnhcc/ml-mvc": "*"
    },
    "suggest": {
        "ext-pdo": "Required for database access via the MVC layer",
        "ext-imap": "Required for IMAP/email features"
    },
    "repositories": [
        {"type": "path", "url": "../ml-core"},
        {"type": "path", "url": "../ml-bugcatcher"},
        {"type": "path", "url": "../ml-mvc"}
    ],
    "autoload": {
        "classmap": [
            "classes/"
        ]
    },
    "require-dev": {
        "kint-php/kint": "4.x-dev",
        "phpunit/phpunit": "^5.7"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
