{
    "name": "mnhcc/minimalus-layoutilus",
    "description": "Minimalus Layoutilus — example application and project template for the mnhcc/ml-* framework",
    "type": "project",
    "license": "LGPL-2.1-or-later",
    "authors": [
        {
            "name": "Michael Hegenbarth (carschrotter)",
            "email": "mnh@mn-hegenbarth.de",
            "homepage": "https://github.com/carschrotter",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=5.4",
        "ext-json": "*",
        "ext-pdo": "*",
        "mnhcc/ml-core": "*",
        "mnhcc/ml-bugcatcher": "*",
        "mnhcc/ml-mvc": "*"
    },
    "repositories": [
        {"type": "path", "url": "../ml-core"},
        {"type": "path", "url": "../ml-bugcatcher"},
        {"type": "path", "url": "../ml-mvc"}
    ],
    "autoload": {
        "classmap": [
            "classes/"
        ]
    },
    "require-dev": {
        "kint-php/kint": "4.x-dev",
        "phpunit/phpunit": "^5.7"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
